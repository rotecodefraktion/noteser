{
  "name": "noteser",
  "version": "0.2.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev --turbopack -H 0.0.0.0 -p 3001",
    "dev:fresh": "rm -rf .next && next dev --turbopack -H 0.0.0.0 -p 3001",
    "build": "next build",
    "start": "next start",
    "prettier": "prettier --write .",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "e2e": "playwright test",
    "e2e:ci": "playwright test --config playwright.config.ci.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "e2e:sync": "node scripts/run-e2e-sync.js",
    "e2e:sync:codeberg": "node scripts/run-e2e-sync-codeberg.js",
    "e2e:ui:codeberg": "node scripts/run-e2e-ui-codeberg.js"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/typography": "^0.5.16",
    "@uiw/react-codemirror": "^4.25.9",
    "@vercel/analytics": "^2.0.1",
    "buffer": "^6.0.3",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.0.0",
    "idb-keyval": "^6.2.2",
    "isomorphic-git": "^1.38.1",
    "jszip": "^3.10.1",
    "next": "^15.5.18",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.1.1",
    "y-codemirror.next": "^0.3.5",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9",
    "eslint-config-next": "^15.5.18",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0-beta.3",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.10"
    },
    "prismjs": "^1.30.0"
  }
}
