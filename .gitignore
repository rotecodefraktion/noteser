# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
collab-server/node_modules
collab-server/dist
collab-server/.wrangler
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# logs
logs
*.log
lerna-debug.log*
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# runtime data
pids
*.pid
*.seed
*.pid.lock

# cache directories
.cache/
.parcel-cache/
.next/cache

# package manager caches
.npm/
.eslintcache
.stylelintcache
.node_repl_history

# IDEs
.idea/

# env files (can opt-in for committing if needed)
.env*

# Local Claude session secrets — never commit. Stores e.g. the Vercel
# API token used to fetch preview URLs.
.claude/*.env
# Per-machine Claude Code permission settings — local only, not shared.
.claude/settings.local.json


# typescript
*.tsbuildinfo
next-env.d.ts

# VS code
/.vscode/

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/blob-report/
.claude/worktrees/

# Vercel
.vercel/
